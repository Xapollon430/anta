---
// A collapsible documentation section: a styled <details>/<summary>
// whose header matches the visual scale of an `##` (h2) heading so a
// `<Disclosure title="…">` reads like the section heading it replaces.
// Used on the component pages to fold the Props and Component tokens
// references away by default (the live demo stays the focus).
//
// The title is a real heading element (`h{level}`) carrying the `id`, so
// it shows up in the page's table of contents (`<a-toc>` scans real
// headings). The id lives on the heading — not the <details> — but existing
// deep links — e.g. `#component-tokens` — keep resolving (the script below
// opens the enclosing block when one is targeted).
interface Props {
  title: string
  /** Start expanded. Defaults to collapsed. */
  open?: boolean
  /** Anchor id. Defaults to a slug of `title`. */
  id?: string
  /** Heading level for the title. Defaults to 2 (top-level section). */
  level?: 2 | 3 | 4 | 5 | 6
}

const { title, open = false, id, level = 2 } = Astro.props
const slug = (id ?? title)
  .toLowerCase()
  .replace(/[^a-z0-9]+/g, '-')
  .replace(/(^-|-$)/g, '')
const Heading = `h${level}` as const
---

<details class="disclosure" open={open}>
  <summary class="summary">
    <a-icon shape="chevron-right" class="chevron" style="--icon-size: 18px"></a-icon>
    {/* A real heading carries the id so the TOC picks it up; the inner
        anchor mirrors rehype-autolink-headings' `behavior: 'wrap'` output
        (classes `header-anchor muted`) so the section deep-links and
        hover-underlines like every other `##` heading. */}
    <Heading id={slug} class="title">
      <a class="header-anchor muted" href={`#${slug}`}>{title}</a>
    </Heading>
  </summary>
  <div class="body">
    <slot />
  </div>
</details>

<style>
  .disclosure {
    margin-block: 32px 0;
  }

  .summary {
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    user-select: none;
    color: var(--text-1);
    /* Hide the default disclosure triangle — the chevron replaces it. */
    list-style: none;
  }
  .summary::-webkit-details-marker {
    display: none;
  }

  /* The title is a real heading; its type scale comes from reset.css.
     Just drop the heading's block margin so it sits inline with the
     chevron in the summary row. */
  .title {
    margin: 0;
  }

  .chevron {
    color: var(--text-3);
    flex-shrink: 0;
    transition: transform 150ms ease-out, color 120ms ease-out;
  }
  .summary:hover .chevron {
    color: var(--text-1);
  }
  .disclosure[open] > .summary .chevron {
    transform: rotate(90deg);
  }

  /* Gap below the summary. Lives as padding (not margin) so it sits
     inside the clipped grid item and collapses with the row during the
     expand/collapse animation below. */
  .body {
    padding-top: 12px;
  }

  /* Animate expand / collapse. `::details-content` (Baseline) wraps the
     content after <summary>; animate its grid row 0fr↔1fr (works in
     Chrome/Firefox/Safari). Overflow is clipped while the row animates
     and dropped once open + idle, so descendants (the playground corner
     grip, Monaco popups, focus rings) aren't cut off when expanded. */
  @media (prefers-reduced-motion: no-preference) {
    .disclosure::details-content {
      display: grid;
      grid-template-rows: 0fr;
      transition: grid-template-rows 240ms ease, content-visibility 240ms ease;
      transition-behavior: allow-discrete;
    }
    .disclosure[open]::details-content {
      grid-template-rows: 1fr;
    }
    /* The grid item collapses + clips while the row animates. `clip`
       (not hidden) avoids creating a scroll container. */
    .disclosure .body {
      min-height: 0;
      overflow: clip;
    }
    /* Drop the clip once open + idle: `overflow 0s 240ms` defers the
       clip→visible flip to after the expand. On collapse the [open] rule
       stops applying, so overflow snaps back to clip immediately and the
       fold stays clipped throughout. */
    .disclosure[open] .body {
      overflow: visible;
      transition: overflow 0s 240ms;
      transition-behavior: allow-discrete; /* required for the delayed discrete flip */
    }
    /* Deep-link / anchor opens skip the animation (the script adds this
       briefly) so the layout is final before we scroll to the target. */
    .disclosure.no-anim::details-content,
    .disclosure.no-anim .body {
      transition: none;
    }
  }
</style>

<script>
  // Make the disclosure headers behave like anchor-linked headings:
  // clicking the header link always EXPANDS the section (never toggles
  // it closed) and deep-links it, and arriving via a `#slug` URL opens
  // the targeted section. Bundled once per page by Astro regardless of
  // how many <Disclosure>s render, so it queries them all.
  // Open the disclosure that contains the element with the given id —
  // works for a block's own title heading AND for any heading nested in
  // its body (so TOC entries inside a folded block expand it).
  function openContaining(id: string): Element | null {
    if (!id) return null
    const target = document.getElementById(id)
    const details = target?.closest('details.disclosure')
    if (details instanceof HTMLDetailsElement && !details.open) {
      // Deep-link / anchor open: expand instantly (no animation) so the
      // page height is final before we scroll — otherwise the smooth
      // scroll chases a moving target as the 0fr→1fr row grows. Re-enable
      // the animation after the open commits so manual toggles still animate.
      details.classList.add('no-anim')
      details.open = true
      requestAnimationFrame(() =>
        requestAnimationFrame(() => details.classList.remove('no-anim')),
      )
    }
    return target
  }

  // Deep links (shared URL, in-page nav): expand + scroll to the target.
  function syncFromHash() {
    const target = openContaining(decodeURIComponent(location.hash.slice(1)))
    if (target) target.scrollIntoView({ block: 'start' })
  }
  syncFromHash()
  window.addEventListener('hashchange', syncFromHash)

  // Header-link click: own the interaction so the section opens rather
  // than relying on the native <summary> toggle (which doesn't fire for
  // a nested link). stopPropagation keeps it from toggling closed; the
  // chevron / summary still toggles normally for collapsing.
  for (const a of document.querySelectorAll<HTMLAnchorElement>(
    'details.disclosure > summary :is(h2,h3,h4,h5,h6) > a.header-anchor',
  )) {
    a.addEventListener('click', (e) => {
      e.preventDefault()
      e.stopPropagation()
      const details = a.closest('details')
      const headingId = a.closest('[id]')?.id
      if (!details) return
      details.open = true
      if (headingId) location.hash = headingId
    })
  }
</script>
