---
import api from '../api.json'
import { marked } from 'marked'

interface Props {
  component: string
}

const { component } = Astro.props

// Find the component's props interface (e.g., "Progress" → "ProgressProps")
const propsName = `${component}Props`
const iface = (api as any).children?.find((c: any) => c.name === propsName)

function renderType(type: any): string {
  if (!type) return '—'
  switch (type.type) {
    case 'intrinsic':
      return type.name
    case 'literal':
      return typeof type.value === 'string' ? `'${type.value}'` : String(type.value)
    case 'union':
      return type.types.map(renderType).join(' | ')
    case 'reference':
      if (type.name) return type.name
      return '—'
    case 'array':
      return `${renderType(type.elementType)}[]`
    case 'typeOperator':
      // Surface known canonical aliases by name rather than inlining.
      // The IconShape type is `keyof IconShapes` — show it as `IconShape`.
      if (type.operator === 'keyof' && type.target?.name === 'IconShapes') {
        return 'IconShape'
      }
      return `${type.operator} ${renderType(type.target)}`
    default:
      return type.name || '—'
  }
}

// TypeDoc splits a JSDoc summary into parts (`text` prose + `code`
// spans whose `text` keeps its backticks), so joining the raw `text`
// of every part reconstructs the original markdown source. Render it
// as inline markdown (no wrapping <p>) so `` `code` ``, **bold**,
// links, etc. in prop descriptions display formatted in the table.
function renderDescription(comment: any): string {
  if (!comment?.summary) return ''
  const md = comment.summary.map((part: any) => part.text).join('')
  return marked.parseInline(md) as string
}

const props = iface?.children
  ?.filter((p: any) => !p.inheritedFrom)
  ?.sort((a: any, b: any) => {
    // Required props first, then alphabetical
    const aOpt = a.flags?.isOptional ? 1 : 0
    const bOpt = b.flags?.isOptional ? 1 : 0
    if (aOpt !== bOpt) return aOpt - bOpt
    return a.name.localeCompare(b.name)
  }) ?? []

const inherited = iface?.children
  ?.filter((p: any) => p.inheritedFrom) ?? []
---

{props.length > 0 && (
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Prop</th>
          <th>Type</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        {props.map((p: any) => (
          <tr>
            <td>
              <code>{p.name}{p.flags?.isOptional ? '?' : ''}</code>
            </td>
            <td><code>{renderType(p.type)}</code></td>
            <td set:html={renderDescription(p.comment)} />
          </tr>
        ))}
      </tbody>
    </table>
  </div>
)}

{inherited.length > 0 && (
  <details>
    <summary>Inherited props ({inherited.map((p: any) => p.name).join(', ')})</summary>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Prop</th>
            <th>Type</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          {inherited.map((p: any) => (
            <tr>
              <td><code>{p.name}?</code></td>
              <td><code>{renderType(p.type)}</code></td>
              <td set:html={renderDescription(p.comment)} />
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </details>
)}
