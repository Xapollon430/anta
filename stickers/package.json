{
  "name": "@antadesign/stickers",
  "version": "0.1.0-dev.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "packageManager": "pnpm@8.13.1",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./elements": {
      "types": "./dist/elements/index.d.ts",
      "default": "./dist/elements/index.js"
    },
    "./elements/*": {
      "types": "./dist/elements/*.d.ts",
      "default": "./dist/elements/*.js"
    },
    "./generate-stickers.mjs": "./dist/generate-stickers.mjs",
    "./*": {
      "types": "./dist/generated/*.d.ts",
      "default": "./dist/generated/*.js"
    }
  },
  "scripts": {
    "build": "pnpm run build:js && pnpm run build:css && pnpm run build:types",
    "build:css": "find src -name '*.css' | while IFS= read -r f; do d=\"dist/${f#src/}\"; mkdir -p \"$(dirname \"$d\")\"; cp \"$f\" \"$d\"; done && cp scripts/generate-stickers.mjs dist/",
    "build:js": "esbuild $(find src \\( -name '*.ts' -o -name '*.tsx' \\) ! -name '*.d.ts') --outdir=dist --outbase=src --jsx=automatic --jsx-import-source=@antadesign/anta --format=esm --target=ES2022 --loader:.module.css=local-css --loader:.css=global-css",
    "build:types": "tsc -p src/tsconfig.json",
    "typecheck": "tsc --noEmit -p src/tsconfig.json",
    "stickers": "node scripts/generate-stickers.mjs --input src/assets --output src/generated --internal",
    "clean": "rm -rf dist",
    "prepare": "pnpm run build",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@antadesign/anta": "workspace:*",
    "lottie-web": "^5.13.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "publishConfig": {
    "access": "public",
    "tag": "dev"
  }
}
